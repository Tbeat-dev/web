{
  "name": "newweb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "node server/index.js",
    "dev": "vite",
    "dev:server": "node --watch server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "server": "node server/index.js",
    "db:seed": "node server/seed.js",
    "mysql:start": "powershell -ExecutionPolicy Bypass -File scripts/start-mysql.ps1",
    "mysql:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-mysql.ps1",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "react": "latest",
    "react-dom": "latest",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest"
  }
}
